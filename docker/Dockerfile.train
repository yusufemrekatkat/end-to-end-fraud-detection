FROM python:3.11-slim

WORKDIR /app

# Install dependencies first (cached if pyproject.toml unchanged)
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy source code
COPY fraud_detection/ fraud_detection/
COPY data/ data/
COPY models/ models/
COPY logs/ logs/

CMD ["python", "-m", "fraud_detection.training.trainer"]